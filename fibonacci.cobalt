// Cálculo de Fibonacci em Cobalt

func fib(n: int): int begin
    if n <= 1 then
        return n;
    end
    return fib(n - 1) + fib(n - 2);
end

func main(): void begin
    var n: int = 10;
    print("Calculando Fibonacci de:");
    print(n);
    
    var resultado: int = fib(n);
    print("O resultado é:");
    print(resultado);
end
